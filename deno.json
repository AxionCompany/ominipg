{
  "name": "@oxian/ominipg",
  "description": "Ominipg is the flexible, all-in-one toolkit for PostgreSQL in Deno.",
  "version": "0.8.3",
  "author": "Ominipg",
  "license": "MIT",
  "exports": {
    ".": "./src/client/index.ts",
    "./auto": "./src/auto.ts",
    "./crud": "./src/client/crud/index.ts",
    "./pglite": "./src/providers/pglite.ts",
    "./pg": "./src/providers/pg.ts",
    "./worker": "./src/worker/index.ts"
  },
  "tasks": {
    "build:npm": "deno run -A scripts/build_npm.ts",
    "memory:deno": "deno run -A --v8-flags=--expose-gc experiments/memory/run_deno_compare.ts",
    "memory:deno:matrix": "deno run -A --v8-flags=--expose-gc experiments/memory/run_deno_matrix.ts",
    "memory:pglite:prepopulate": "deno run -A --v8-flags=--expose-gc experiments/memory/run_pglite_prepopulate.ts",
    "memory:pglite:tune": "deno run -A --v8-flags=--expose-gc experiments/memory/run_pglite_tuning.ts",
    "memory:node:pglite": "env PGLITE_NODE_MODULE_ROOT=./npm node --expose-gc experiments/memory/pglite_node.mjs",
    "test:deno": "deno test --allow-all",
    "test:npm-node": "deno task build:npm && deno run -A scripts/test_npm_node.ts"
  },
  "test": {
    "include": [
      "test/**/*.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AxionCompany/ominipg"
  },
  "lock": false
}
